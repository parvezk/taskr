# Neon Postgres connection string
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Neon Auth configuration
# IMPORTANT: this must include the /auth path suffix, e.g.:
#   https://ep-xxx.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth
# It should match the NEON_AUTH_URL value shown in your Neon project dashboard.
NEON_AUTH_BASE_URL=https://your-project.neonauth.region.aws.neon.tech/neondb/auth

# GitHub OAuth (for Neon Auth social login)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
